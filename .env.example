# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Ollama
# Use http://localhost:11434 when running uvicorn on the host machine.
# Use http://ollama:11434 when running inside Docker Compose on the same network as the ollama service.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_TOKENS=256
OLLAMA_TEMPERATURE=0.2

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=rag_documents
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE=Cosine

# RAG
